rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: admins
    // Document ID: user's Firebase UID
    // Fields:
    //   - uid: string (matches document ID)
    //   - email: string (admin email)
    //   - displayName: string (admin display name)
    //   - createdAt: timestamp (when admin role was granted)
    //   - grantedBy: string (email of who granted admin status)
    //
    // Collection: products
    // Document ID: auto-generated or custom
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - category: string (required, 1-50 chars)
    //   - quantity: number (optional, >= 0)
    //   - status: string (required, enum: ['In Stock', 'Out of Stock', 'Newly Added', 'Back in Stock'])
    //   - size: string (optional)
    //   - price: number (optional, >= 0)
    //   - imageUrl: string (optional)
    //   - websiteUrl: string (optional)
    //   - launchDate: string (optional)
    //   - tags: list (optional)
    //   - ribbon: string (optional)
    //   - releasedBatch: string (optional)
    //   - updatedAt: timestamp (required)
    //   - updatedBy: string (required, UID)
    //
    // Collection: logs
    // Document ID: auto-generated
    // Fields:
    //   - action: string (required, enum: ['create', 'update', 'delete'])
    //   - productId: string (required)
    //   - productName: string (required)
    //   - timestamp: timestamp (required)
    //   - userEmail: string (required)
    //   - details: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'category', 'status', 'updatedAt', 'updatedBy']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 50 &&
             (!('quantity' in data) || (data.quantity == null || (data.quantity is number && data.quantity >= 0))) &&
             data.status in ['In Stock', 'Out of Stock', 'Newly Added', 'Back in Stock'] &&
             (!('size' in data) || (data.size is string && data.size.size() <= 100)) &&
             (!('price' in data) || (data.price is number && data.price >= 0)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 1000)) &&
             (!('websiteUrl' in data) || (data.websiteUrl is string && data.websiteUrl.size() <= 1000)) &&
             (!('launchDate' in data) || (data.launchDate == null || (data.launchDate is string && data.launchDate.size() <= 20))) &&
             (!('tags' in data) || (data.tags is list)) &&
             (!('ribbon' in data) || (data.ribbon == null || (data.ribbon is string && data.ribbon.size() <= 50))) &&
             (!('releasedBatch' in data) || (data.releasedBatch == null || (data.releasedBatch is string && data.releasedBatch.size() <= 50))) &&
             data.updatedAt is timestamp &&
             data.updatedBy is string;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['action', 'productId', 'productName', 'timestamp', 'userEmail']) &&
             data.action in ['create', 'update', 'delete'] &&
             data.productId is string &&
             data.productName is string &&
             data.timestamp is timestamp &&
             data.userEmail is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /admins/{userId} {
      allow read: if isAuthenticated();
      allow create: if request.auth.uid == userId; // Users can create their own admin profile
      allow update: if request.auth.uid == userId; // Users can only update their own
      allow delete: if isAdmin() && request.auth.uid != userId; // Only other admins can delete
    }

    match /products/{productId} {
      allow read: if true; // Publicly readable as per requirements
      allow create: if isAuthenticated() && isValidProduct(request.resource.data);
      allow update: if isAuthenticated() && isValidProduct(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /logs/{logId} {
      allow read: if isAuthenticated(); // Authenticated users can see logs
      allow create: if isAuthenticated() && isValidLog(request.resource.data);
      allow update: if false; // Logs should be immutable
      allow delete: if false; // Logs should be immutable
    }
  }
}
