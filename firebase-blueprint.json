{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An item in the inventory",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the product" },
        "category": { "type": "string", "description": "Category of the product" },
        "quantity": { "type": "number", "description": "Current stock quantity" },
        "status": { "type": "string", "enum": ["In Stock", "Out of Stock", "Newly Added", "Back in Stock"], "description": "Current status of the product" },
        "size": { "type": "string", "description": "Physical size or dimensions of the product" },
        "price": { "type": "number", "description": "Price of the product" },
        "imageUrl": { "type": "string", "description": "URL of the product image" },
        "websiteUrl": { "type": "string", "description": "Product page link" },
        "launchDate": { "type": "string", "format": "date", "description": "Date the product was launched" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Tags like New Arrival, Best Seller" },
        "ribbon": { "type": "string", "description": "Ribbon label like Sale, Popular" },
        "releasedBatch": { "type": "string", "description": "Batch info" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" },
        "updatedBy": { "type": "string", "description": "UID of the user who last updated the product" }
      },
      "required": ["name", "category", "status", "updatedAt"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "A record of a change made to the inventory",
      "type": "object",
      "properties": {
        "action": { "type": "string", "enum": ["create", "update", "delete"], "description": "The action performed" },
        "productId": { "type": "string", "description": "ID of the affected product" },
        "productName": { "type": "string", "description": "Name of the product at the time of the action" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the action occurred" },
        "userEmail": { "type": "string", "description": "Email of the user who performed the action" },
        "details": { "type": "string", "description": "Optional details about the change" }
      },
      "required": ["action", "productId", "productName", "timestamp", "userEmail"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of inventory products"
    },
    "/logs/{logId}": {
      "schema": "ActivityLog",
      "description": "Collection of activity logs"
    }
  }
}
